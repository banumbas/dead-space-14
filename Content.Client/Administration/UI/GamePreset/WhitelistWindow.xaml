<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc game-preset-whitelist-window-title}"
               MinSize="400 300"
               SetSize="500 400">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="8">
        <Label Text="{Loc game-preset-whitelist-description}" StyleClasses="LabelSubText" />
        <ScrollContainer VerticalExpand="True">
            <GridContainer Name="ModesGrid" Columns="2" />
        </ScrollContainer>
        <Button Name="SaveButton" Text="{Loc game-preset-save-button}" />
    </BoxContainer>
</DefaultWindow>